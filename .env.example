# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/russia_science_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=russia_science_hub

# Redis (for caching and task queue)
REDIS_URL=redis://localhost:6379/0

# OpenAI (for embeddings and Q&A)
OPENAI_API_KEY=sk-...

# Security
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Storage
PAPERS_STORAGE_PATH=./storage/papers
MAX_FILE_SIZE_MB=50

# Crawler Settings
CRAWLER_DELAY_SECONDS=2
CRAWLER_MAX_RETRIES=3
CRAWLER_CONCURRENT_REQUESTS=5

# Proxy Rotation (for Google Scholar / eLibrary crawling at scale)
# Comma-separated list of proxy URLs. Supports http, https, socks5.
# Example: socks5://user:pass@host1:1080,http://user:pass@host2:8080
PROXY_LIST=
# Or load from file (one proxy per line):
PROXY_FILE=

# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME="Russian Science Hub"
PROJECT_VERSION=0.1.0

# Elasticsearch (optional, for advanced search)
ELASTICSEARCH_URL=http://localhost:9200
USE_ELASTICSEARCH=false

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Frontend URL
FRONTEND_URL=http://localhost:5173
